# Скопировать в backend/.env и заполнить реальными значениями

# LLM (через тот же прокси-провайдер, что и optics_summary)
LLM_PROVIDER=polza
POLZA_AI_API_KEY=your-polza-key
POLZA_AI_BASE_URL=https://polza.ai/api/v1
CLAUDE_MODEL=anthropic/claude-sonnet-4.5

# Маршрутизация / гео
ROUTING_PROVIDER=osrm
OSRM_BASE_URL=https://router.project-osrm.org
YANDEX_MAPS_API_KEY=
HTTP_USER_AGENT=Roadcast/0.1 (contact: your-email@example.com)
HTTP_TIMEOUT_SECONDS=15.0
ROUTE_SAMPLE_STEP_KM=5.0
WIKIPEDIA_GEOSEARCH_RADIUS_M=7000

# TTS
TTS_PROVIDER=openai
TTS_API_KEY=

# База данных
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/roadcast

# CORS
CORS_ORIGINS=["http://localhost:3000"]
